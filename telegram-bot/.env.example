# ─── Telegram ──────────────────────────────────────────────
# From @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Numeric Telegram user/chat id allowed to use this bot (use @userinfobot to get it)
TELEGRAM_ADMIN_CHAT_ID=123456789

# ─── Cloudflare R2 (S3-compatible) ────────────────────────
# Endpoint looks like: https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=ohayou-anime
# Public base URL for files (custom domain bound to the bucket, no trailing slash)
R2_PUBLIC_BASE_URL=https://cdn.ohayouanime.com

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# IMPORTANT: service role key — server-only. NEVER ship to a client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# UUID of the admin user that owns inserted rows (must exist in auth.users / have admin role)
SUPABASE_ADMIN_USER_ID=00000000-0000-0000-0000-000000000000
